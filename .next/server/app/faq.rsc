7:["$","main",null,{"children":["$","$L16",null,{"intro":"Find answers about our warranty, returns, shipping, and mango refund policy. If you need more help, our team is available around the clock.","categories":[{"id":"shipping","title":"Shipping","image":"/images/dasheri-mango.png","alt":"Shipping — FAQ","defaultOpenId":"cmq12gxxa001s66r0ew07oqru","items":[{"id":"cmq12gxxa001s66r0ew07oqru","question":"Do you deliver nationwide?","answer":"Yes, we deliver across Pakistan with orchard-fresh packaging. International shipping is available on select orders."},{"id":"cmq12gxxd001t66r0xzyyl66c","question":"How long does delivery take?","answer":"Most orders arrive within 1–3 business days depending on your city."}]},{"id":"returns","title":"Returns","image":"/images/chaunsa-premium-variety.png","alt":"Returns — FAQ","defaultOpenId":"cmq12gxxf001u66r07v4wp7k9","items":[{"id":"cmq12gxxf001u66r07v4wp7k9","question":"What if my mangoes arrive damaged?","answer":"Contact us within 24 hours with photos and we will arrange a replacement or refund."}]},{"id":"products","title":"Products","image":"/images/anwar-ratol-mango.png","alt":"Products — FAQ","defaultOpenId":"cmq12gxxh001v66r0c6baw7uy","items":[{"id":"cmq12gxxh001v66r0c6baw7uy","question":"Are your mangoes export quality?","answer":"Yes, every mango is hand-selected and graded for export quality from Multan and Sindh orchards."}]}],"emergencyPhone":"+92 307 3970850","emergencyPhoneHref":"tel:+923073970850"}]}]
